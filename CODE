import json
import urllib3

http = urllib3.PoolManager()

EC2_DETECT_URL = 'http://44.200.114.250:5000/detect'

def lambda_handler(event, context):
    try:
        # Check if triggered by S3 or by API Gateway
        if 'Records' in event:
            # S3 trigger
            record = event['Records'][0]['s3']
            bucket_name = record['bucket']['name']
            image_key = record['object']['key']
        else:
            # API Gateway trigger
            body = event.get('body')
            if isinstance(body, str):
                body = json.loads(body) 
            bucket_name = body['bucket']
            image_key = body['key']  

        print(f"Processing: s3://{bucket_name}/{image_key}")

        response = http.request(
            'POST',
            EC2_DETECT_URL,
            headers={'Content-Type': 'application/json'},
            body=json.dumps({'bucket': bucket_name, 'key': image_key}),
            timeout=urllib3.Timeout(connect=10, read=110)
        )

        result_data = json.loads(response.data.decode('utf-8')) 
        print(f"Detection result: {result_data}")

        return {
            'statusCode': 200,
            'headers': {'Content-Type': 'application/json'},
            'body': json.dumps(result_data)
        }

    except Exception as e:
        print(f"Error: {str(e)}")
        return {
            'statusCode': 500,
            'headers': {'Content-Type': 'application/json'},
            'body': json.dumps({'error': str(e)})
        }

